callee - {[-1]:Integer} |{[-1]:Pointer}:{} 
ptr %X: {[-1]:Pointer, [-1,0]:Integer, [-1,1]:Integer, [-1,2]:Integer, [-1,3]:Integer}

  %X = load i32, ptr %X, align 4, !dbg !N, !noundef !N: {[-1]:Integer}
  %X = mul i32 %X, %X, !dbg !N: {[-1]:Integer}
  ret i32 %X, !dbg !N: {}
callee - {[-1]:Integer} |{[-1]:Pointer, [-1,0]:Integer, [-1,1]:Integer, [-1,2]:Integer, [-1,3]:Integer}:{} 
ptr %X: {[-1]:Pointer, [-1,0]:Integer, [-1,1]:Integer, [-1,2]:Integer, [-1,3]:Integer}

  %X = load i32, ptr %X, align 4, !dbg !N, !noundef !N: {[-1]:Integer}
  %X = mul i32 %X, %X, !dbg !N: {[-1]:Integer}
  ret i32 %X, !dbg !N: {}
