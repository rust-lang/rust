   LL|       |//@ edition: 2021
   LL|       |//@ proc-macro: proc_macro_demo_helper.rs
   LL|       |
   LL|       |// Regression test for functions whose bodies consist entirely of code
   LL|       |// generated by a proc-macro expansion (e.g. the impls generated by a
   LL|       |// `#[derive(...)]` macro, or a function body generated by an attribute
   LL|       |// macro). All of their statement spans point at the macro invocation site,
   LL|       |// and between Rust 1.83 and 1.84 the span refinement changes caused all of
   LL|       |// those spans to be discarded, leaving such functions either completely
   LL|       |// uninstrumented or (in some versions) with a single leftover region wired
   LL|       |// to an arbitrary non-entry counter that reads 0 forever.
   LL|       |//
   LL|       |// The desired behavior is that the visible macro invocation site (the derive
   LL|       |// macro path, or the attribute) gets a region wired to the generated
   LL|       |// function's *entry* counter, so the invocation line reports how many times
   LL|       |// the generated code was executed. Generated functions that are never called
   LL|       |// mark their invocation site as executable-but-unexecuted (count 0), which is
   LL|       |// covered as soon as any sibling function from the same invocation runs.
   LL|       |
   LL|       |extern crate proc_macro_demo_helper;
   LL|       |use proc_macro_demo_helper::{Demo, generate_body};
   LL|       |
   LL|       |// Generates `demo` (called 3 times below) and `never_called` (never called).
   LL|       |// This line should report the total execution count of the generated code.
   LL|      3|#[derive(Demo)]
  ------------------
  | <proc_macro_derive_span::Used>::demo:
  |   LL|      3|#[derive(Demo)]
  ------------------
  | Unexecuted instantiation: <proc_macro_derive_span::Used>::never_called
  ------------------
   LL|       |struct Used;
   LL|       |
   LL|       |// Same derive, but nothing generated from it is ever called, and the type
   LL|       |// itself is unused. This line is executable but reports 0.
   LL|      0|#[derive(Demo)]
  ------------------
  | Unexecuted instantiation: <proc_macro_derive_span::Unused>::demo
  ------------------
  | Unexecuted instantiation: <proc_macro_derive_span::Unused>::never_called
  ------------------
   LL|       |struct Unused;
   LL|       |
   LL|       |// The function body is replaced entirely with generated code. The attribute
   LL|       |// line reports the number of calls to the generated function.
   LL|      1|#[generate_body]
   LL|       |fn attr_generated(_: ()) {}
   LL|       |
   LL|      1|fn main() {
   LL|      1|    assert_eq!(Used.demo(1), 2);
   LL|      1|    assert_eq!(Used.demo(50), 100);
   LL|      1|    assert_eq!(Used.demo(100), 200);
   LL|      1|    assert_eq!(attr_generated(20), 40);
   LL|      1|}

