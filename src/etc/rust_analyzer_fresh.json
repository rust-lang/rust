{
  "lsp": {
    "rust": {
      "auto_start": true,
      "command": "rust-analyzer",
      "enabled": true,
      "initialization_options": {
        "check": {
          "invocationStrategy": "once",
          "check.overrideCommand": [
            "python3",
            "x.py",
            "check",
            "--json-output",
            "--build-dir",
            "build-rust-analyzer"
          ]
        },
        "linkedProjects": [
            "Cargo.toml",
            "compiler/rustc_codegen_cranelift/Cargo.toml",
            "compiler/rustc_codegen_gcc/Cargo.toml",
            "library/Cargo.toml",
            "src/bootstrap/Cargo.toml",
            "src/tools/rust-analyzer/Cargo.toml"
        ],
        "rustfmt": {
          "overrideCommand": [
            "${workspaceFolder}/build/host/rustfmt/bin/rustfmt",
            "--edition=2024"
          ]
        },
        "cargo": {
          "buildScripts": {
            "enable": true,
            "invocationStrategy": "once",
            "overrideCommand": [
              "python3",
              "x.py",
              "check",
              "--json-output",
              "--build-dir",
              "build-rust-analyzer"
            ]
          }
        },
        "server": {
          "extraEnv": {
            "RUSTUP_TOOLCHAIN": "nightly"
          }
        }
      },
      "process_limits": {
        "max_memory_percent": 80,
        "max_cpu_percent": 90,
        "enabled": true
      }
    }
  }
}
