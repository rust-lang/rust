#![no_std]
#![warn(clippy::unused_async_trait_impl)]

trait HasAsyncMethod {
    async fn do_something() -> u32;
}

struct Inefficient;

impl HasAsyncMethod for Inefficient {
    fn do_something() -> impl Future<Output = u32> {
        //~^ unused_async_trait_impl
        core::future::ready(1)
    }
}
