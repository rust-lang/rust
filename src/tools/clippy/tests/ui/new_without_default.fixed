pub struct NewNotEqualToDerive {
    foo: i32,
}

impl NewNotEqualToDerive {
    // This `new` implementation is not equal to a derived `Default`, so do not suggest deriving.
    pub fn new() -> Self {
        //~^ new_without_default

        NewNotEqualToDerive { foo: 1 }
    }
}

impl Default for NewNotEqualToDerive {
    fn default() -> Self {
        Self::new()
    }
}

