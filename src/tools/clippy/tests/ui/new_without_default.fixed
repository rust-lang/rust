#![warn(clippy::new_without_default)]
#![expect(clippy::extra_unused_lifetimes, clippy::missing_safety_doc)]

pub struct Foo;

impl Foo {
    pub fn new() -> Foo {
        //~^ new_without_default

        Foo
    }
}

impl Default for Foo {
    fn default() -> Self {
        Self::new()
    }
}

