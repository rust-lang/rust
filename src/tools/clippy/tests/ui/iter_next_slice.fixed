#![warn(clippy::iter_next_slice)]
#![expect(clippy::useless_vec)]

fn main() {
    // test code goes here
    let s = [1, 2, 3];
    let v = vec![1, 2, 3];

    let _ = s.first();
    //~^ iter_next_slice
    // Should be replaced by s.first()

    let _ = s.get(2);
    //~^ iter_next_slice
    // Should be replaced by s.get(2)

    let _ = v.get(5);
    //~^ iter_next_slice
    // Should be replaced by v.get(5)

    let _ = v.first();
    //~^ iter_next_slice
    // Should be replaced by v.first()

    let o = Some(5);
    o.iter().next();
    // Shouldn't be linted since this is not a Slice or an Array

    let mut s_mut = [1, 2, 3];
    let mut v_mut = vec![1, 2, 3];

    let _: Option<&mut i32> = s_mut.first_mut();
    //~^ iter_next_slice

    let _ = v_mut.first_mut();
    //~^ iter_next_slice
}
