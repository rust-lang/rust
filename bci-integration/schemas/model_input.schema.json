{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw.dev/schemas/model_input.schema.json",
  "title": "OpenClawModelInput",
  "version": "0.1.0",
  "description": "Schema for feeding BCI features into the OpenClaw model layer.",
  "type": "object",
  "required": ["request_id", "timestamp_unix_ms", "intent", "bci_context"],
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string",
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_.-]{1,128}$",
      "description": "Unique request ID for tracing through the pipeline."
    },
    "timestamp_unix_ms": {
      "type": "integer"
    },
    "intent": {
      "type": "string",
      "enum": ["classify_state", "predict_action", "adapt_model", "raw_passthrough"],
      "description": "What the model should do with this BCI data."
    },
    "bci_context": {
      "type": "object",
      "description": "BCI-derived context for the model.",
      "required": ["session_id", "device_id", "signal_quality"],
      "additionalProperties": false,
      "properties": {
        "features": {
          "type": "object",
          "description": "Processed features (required unless intent is raw_passthrough).",
          "properties": {
            "band_powers": {
              "type": "object",
              "properties": {
                "delta": { "type": "number", "minimum": 0 },
                "theta": { "type": "number", "minimum": 0 },
                "alpha": { "type": "number", "minimum": 0 },
                "beta": { "type": "number", "minimum": 0 },
                "gamma": { "type": "number", "minimum": 0 }
              }
            },
            "attention_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "relaxation_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "cognitive_load": { "type": "number", "minimum": 0, "maximum": 1 },
            "artifact_probability": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "signal_quality": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "device_id": {
          "type": "string",
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9_.-]{1,128}$"
        },
        "session_id": {
          "type": "string",
          "maxLength": 128,
          "pattern": "^[a-zA-Z0-9_.-]{1,128}$"
        },
        "source_packet_range": {
          "type": "object",
          "properties": {
            "first_packet_id": { "type": "integer", "minimum": 0 },
            "last_packet_id": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "model_params": {
      "type": "object",
      "description": "Optional model-specific parameters.",
      "additionalProperties": false,
      "properties": {
        "model_id": {
          "type": "string",
          "maxLength": 128,
          "description": "Which model to use for inference."
        },
        "confidence_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.7
        },
        "max_latency_ms": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum acceptable latency for response.",
          "default": 100
        }
      }
    }
  }
}
