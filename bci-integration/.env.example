# BCI-OpenClaw Integration - Environment Variables
# Copy to .env and modify as needed. All have sensible defaults.

# ── Server ───────────────────────────────────────────────────────────
BCI_PORT=7680
BCI_HOST=127.0.0.1

# ── DSP ──────────────────────────────────────────────────────────────
BCI_SAMPLE_RATE=250
BCI_WINDOW_SIZE_MS=1000
BCI_WINDOW_STEP_MS=250

# ── Thresholds ───────────────────────────────────────────────────────
BCI_ARTIFACT_AMPLITUDE_UV=100.0
BCI_STALE_THRESHOLD_MS=2000
BCI_STALE_WARNING_MS=5000

# ── Pause Detection ─────────────────────────────────────────────────
BCI_CLENCH_THRESHOLD_FACTOR=3.0
BCI_CLENCH_WINDOW_S=2.0
BCI_CLENCH_MIN_DURATION_MS=100
BCI_DROWSINESS_WINDOW_SIZE=20
BCI_DROWSINESS_ATTENTION_THRESHOLD=0.25
BCI_HEADSET_REMOVED_WINDOW_SIZE=8
BCI_HEADSET_REMOVED_QUALITY_THRESHOLD=0.05

# ── ML Classifier ───────────────────────────────────────────────────
# BCI_MODEL_PATH=models/brain_state_rf.joblib
# BCI_DEEP_MODEL_PATH=models/eegnet_synthetic.pt

# ── Webhooks ─────────────────────────────────────────────────────────
BCI_WEBHOOK_COOLDOWN_MS=1000
BCI_WEBHOOK_TIMEOUT_S=5

# ── WebSocket ────────────────────────────────────────────────────────
BCI_WS_HEARTBEAT_INTERVAL_S=30

# ── CORS ─────────────────────────────────────────────────────────────
BCI_CORS_ORIGINS=*

# ── OpenClaw Plugin ──────────────────────────────────────────────────
BCI_STATE_SERVER_URL=http://127.0.0.1:7680
BCI_USE_WEBSOCKET=false
